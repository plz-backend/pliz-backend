# DATABASE VERIFICATION COMMANDS
###############################################

# Run these in your terminal to verify data:

# View all users:
# psql pliz_app -c "SELECT username, email, is_email_verified, email_verified_at FROM app_users;"

# View User 1:
# psql pliz_app -c "SELECT * FROM app_users WHERE email = 'impactliveconsult@gmail.com';"

# View User 2:
# psql pliz_app -c "SELECT * FROM app_users WHERE email = 'chigoziegodwin93@gmail.com';"

# View all sessions:
# psql pliz_app -c "SELECT s.id, u.username, s.browser, s.os, s.device, s.active, s.last_active FROM session_manager s JOIN app_users u ON s.user_id = u.id ORDER BY s.last_active DESC;"

# Count active sessions per user:
# psql pliz_app -c "SELECT u.username, COUNT(*) as sessions FROM app_users u JOIN session_manager s ON u.id = s.user_id WHERE s.active = true GROUP BY u.username;"

###############################################
# REDIS VERIFICATION COMMANDS
###############################################

# View all email tokens:
# redis-cli KEYS email_token:*

# View all password reset tokens:
# redis-cli KEYS password_reset:*

# View all blacklisted tokens:
# redis-cli KEYS blacklist:*

# View specific token:
# redis-cli GET email_token:impactliveconsult@gmail.com

# Check token TTL:
# redis-cli TTL email_token:impactliveconsult@gmail.com

# Monitor all Redis operations:
# redis-cli MONITOR

###############################################
# CLEANUP COMMANDS
###############################################

# Delete test users from database:
# psql pliz_app -c "DELETE FROM app_users WHERE email LIKE '%@example.com';"

# Clear all Redis data (CAUTION):
# redis-cli FLUSHDB

# Delete specific email tokens:
# redis-cli DEL email_token:journey@example.com
# redis-cli DEL email_token:resendtest@example.com

