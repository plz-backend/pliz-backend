###############################################
# SECTION 12: COMPLETE BEG LIFECYCLE
###############################################

### Step 1: Create Beg
# @name lifecycleBeg
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "medical",
  "title": "Surgery needed ASAP",
  "description": "Emergency appendectomy required and I need financial assistance for hospital payment",
  "amountRequested": 15000
}

# ✅ Status: Created, pending approval

###

### Step 2: Check in My Begs
GET {{baseUrl}}/api/begs/my-begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}

# ✅ Should see the new beg

###

### Step 3: NOT in Public Feed (Unapproved)
GET {{baseUrl}}/api/begs

# ✅ Should NOT see it yet

###

### Step 4: Admin Approves
PATCH {{baseUrl}}/api/admin/begs/BEG_ID_FROM_STEP_1/approve
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}

# ✅ Beg approved

###

### Step 5: NOW in Public Feed
GET {{baseUrl}}/api/begs

# ✅ Should NOW see it

###

### Step 6: Someone Donates
POST {{baseUrl}}/api/donations/initialize
Authorization: Bearer {{loginUser2.response.body.data.accessToken}}
Content-Type: application/json

{
  "begId": "BEG_ID_FROM_STEP_1",
  "amount": 15000,
  "paymentMethod": "card"
}

# ✅ Donation initialized

###

### Step 7: Complete Payment (Use Paystack Test Card)
# Visit payment_url from Step 6
# Card: 4084 0840 8408 4081
# CVV: 408, Expiry: 12/30, PIN: 0000, OTP: 123456

###

### Step 8: Check Beg Status After Full Funding
GET {{baseUrl}}/api/begs/BEG_ID_FROM_STEP_1
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}

# ✅ Expected: status = "funded"

###

### Step 9: Request Withdrawal
POST {{baseUrl}}/api/withdrawals/request
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "begId": "BEG_ID_FROM_STEP_1"
}

# ✅ Withdrawal created and auto-processed

###

