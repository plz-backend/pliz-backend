###############################################
# PLIZ APP - BEG FEATURE COMPLETE TEST SUITE
# Categories | Trust Tiers | Cooldowns | Validation | Approval Workflow
###############################################

@baseUrl = http://localhost:3000
@user1Email = impactliveconsult@gmail.com
@user1Password = Test123!@#
@user2Email = chigoziegodwin93@gmail.com
@user2Password = Test123!@#
@user3Email = godwinchigozie93@gmail.com
@user3Password = Test123!@#
@adminEmail = admin@pliz.app
@adminPassword = Admin123!@#

###############################################
# SECTION 0: SETUP - LOGIN USERS
###############################################

### 0.1 Login User 1 (Donor/Requester)
# @name loginUser1
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{user1Email}}",
  "password": "{{user1Password}}"
}

# ✅ Expected: 200 OK
# Save: user1Token = response.data.accessToken
# Save: user1Id = response.data.user.id

###

### 0.2 Login User 2 (Requester)
# @name loginUser2
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{user2Email}}",
  "password": "{{user2Password}}"
}

# ✅ Expected: 200 OK

###

### 0.3 Login User 3 (Requester)
# @name loginUser3
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{user3Email}}",
  "password": "{{user3Password}}"
}

# ✅ Expected: 200 OK

###

### 0.4 Login Admin
# @name loginAdmin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

# ✅ Expected: 200 OK

###

###############################################
# SECTION 1: CATEGORY VALIDATION
###############################################

### 1.1 Get Available Categories
GET {{baseUrl}}/api/begs/categories
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}

# ✅ Expected: 200 OK with categories list
# Should return: food, transport, rent, medical, education, emergency, other

###

### 1.2 Create Beg - Valid Category
# @name createBegValidCategory
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "food",
  "title": "Need groceries",
  "description": "Lost my job last week and need help feeding my family",
  "amountRequested": 5000
}

# ✅ Expected: 201 Created
# {
#   "success": true,
#   "message": "Beg created successfully and pending approval.",
#   "data": {
#     "beg": {
#       "id": "...",
#       "title": "Need groceries",
#       "description": "Lost my job last week and need help feeding my family",
#       "approved": false,
#       "status": "active"
#     }
#   }
# }

###

### 1.3 Create Beg - Invalid Category (SHOULD FAIL)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "invalid_category",
  "title": "Test",
  "amountRequested": 1000
}

# ❌ Expected: 400 - "Invalid category"

###

### 1.4 Create Beg - Missing Category (SHOULD FAIL)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "title": "Test",
  "amountRequested": 1000
}

# ❌ Expected: 400 - "Category is required"

###

###############################################
# SECTION 2: TITLE VALIDATION
###############################################

### 2.1 Create Beg - Valid Title (25 chars)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "medical",
  "title": "Need hospital bill help",
  "amountRequested": 10000
}

# ✅ Expected: 201 Created (exactly 25 characters including spaces)

###

### 2.2 Create Beg - Title Too Long (SHOULD FAIL)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "medical",
  "title": "I need urgent help with my medical bills",
  "amountRequested": 10000
}

# ❌ Expected: 400 - "Title must be 25 characters or less"

###

### 2.3 Create Beg - Empty Title (SHOULD FAIL)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "food",
  "title": "   ",
  "amountRequested": 2000
}

# ❌ Expected: 400 - "Title cannot be empty"

###

### 2.4 Create Beg - Missing Title (SHOULD FAIL)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "food",
  "amountRequested": 2000
}

# ❌ Expected: 400 - "Title is required"

###

### 2.5 Create Beg - Title with Special Characters
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "rent",
  "title": "Rent due - need help!",
  "amountRequested": 8000
}

# ✅ Expected: 201 Created (special chars allowed)

###

###############################################
# SECTION 3: DESCRIPTION VALIDATION
###############################################

### 3.1 Create Beg - Valid Description (30 words)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "medical",
  "title": "Surgery needed",
  "description": "I need emergency surgery to remove my appendix. The hospital requires payment upfront and I don't have the money right now. Any help would be greatly appreciated.",
  "amountRequested": 15000
}

# ✅ Expected: 201 Created (exactly 30 words)

###

### 3.2 Create Beg - Description Too Long (SHOULD FAIL)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "medical",
  "title": "Hospital bill",
  "description": "I had an emergency surgery last week at the general hospital and the doctors are saying that I need to pay before they discharge me but I don't have any money right now because I just lost my job",
  "amountRequested": 15000
}

# ❌ Expected: 400 - "Description must be 30 words or less (currently 40 words)"

###

### 3.3 Create Beg - No Description (Valid)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "transport",
  "title": "Need bus fare",
  "amountRequested": 500
}

# ✅ Expected: 201 Created (description is optional)

###

### 3.4 Create Beg - Empty Description (Valid)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "food",
  "title": "Groceries needed",
  "description": "",
  "amountRequested": 3000
}

# ✅ Expected: 201 Created (empty description is ok)

###

### 3.5 Create Beg - Description Exactly 500 Characters
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "emergency",
  "title": "Emergency help",
  "description": "This is a test description that is exactly five hundred characters long to test the maximum character limit validation. We need to ensure that the system properly handles descriptions that reach the maximum allowed length. This helps us verify that our validation logic is working correctly and that users can utilize the full character allowance when providing details about their request for assistance. The description should be accepted without any issues or errors from the backend validation system.",
  "amountRequested": 20000
}

# ✅ Expected: 201 Created (exactly 500 chars)

###

### 3.6 Create Beg - Description Over 500 Characters (SHOULD FAIL)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "emergency",
  "title": "Emergency help",
  "description": "This is a test description that exceeds five hundred characters to test the maximum character limit validation. We need to ensure that the system properly rejects descriptions that are too long. This helps us verify that our validation logic is working correctly and prevents users from submitting overly long descriptions. The description should be rejected with an appropriate error message from the backend validation system. Adding more text here to exceed the limit and trigger the validation error that we expect to see in the response.",
  "amountRequested": 20000
}

# ❌ Expected: 400 - "Description is too long (max 500 characters)"

###

###############################################
# SECTION 4: AMOUNT VALIDATION
###############################################

### 4.1 Create Beg - Valid Amount
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "food",
  "title": "Need groceries",
  "amountRequested": 5000
}

