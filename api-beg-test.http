###############################################
# SECTION 14: DATABASE VERIFICATION
###############################################

# Run these SQL queries to verify data

### 14.1 Check Beg Creation
# SELECT id, title, description, approved, approved_at, rejected_at, 
#        status, amount_requested, created_at
# FROM begs
# WHERE user_id = 'USER_ID'
# ORDER BY created_at DESC;

###

### 14.2 Check Approval Status
# SELECT id, title, approved, approved_at, approved_by
# FROM begs
# WHERE approved = true
# ORDER BY approved_at DESC;

