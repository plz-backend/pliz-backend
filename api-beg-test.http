POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser3.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "medical",
  "title": "Medical emergency",
  "description": "Need urgent medical treatment and cannot afford the hospital bills right now",
