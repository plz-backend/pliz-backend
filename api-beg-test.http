#     "approved": true,
#     "approved_at": "2026-03-10T..."
#   }
# }

###

### 6.4 Check Approved Beg Now in Feed
GET {{baseUrl}}/api/begs?page=1&limit=20
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}

# ✅ Expected: 200 OK
# Should NOW see approved beg in results

###

### 6.5 Get Beg by ID - Check Approval Fields
GET {{baseUrl}}/api/begs/BEG_ID_FROM_6.1
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}

# ✅ Expected: 200 OK
# {
#   "data": {
#     "beg": {
#       "id": "...",
#       "title": "Medical emergency",
#       "description": "Need urgent medical treatment...",
