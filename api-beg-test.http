###############################################
# SECTION 13: COMPLETE BEG LIFECYCLE
###############################################

### Step 1: Create Beg with 24h expiry
# @name lifecycleBeg
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "medical",
  "description": "Emergency appendectomy required and need financial assistance for hospital payment",
  "amountRequested": 9000,
  "expiryHours": 24
}
# ✅ Status: Created, pending approval, expiryHours: 24

###

### Step 2: Check in My Begs
GET {{baseUrl}}/api/begs/my-begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
# ✅ Should see the new beg with expiryHours: 24

###

### Step 3: NOT in Public Feed (Unapproved)
GET {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
# ✅ Should NOT see it yet

###

### Step 4: Admin Approves
PATCH {{baseUrl}}/api/admin/begs/BEG_ID_FROM_STEP_1/approve
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}
# ✅ Beg approved

###

### Step 5: NOW in Public Feed
GET {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
# ✅ Should NOW see it

###

### Step 6: Popup Fires - Check Expiring Begs
GET {{baseUrl}}/api/begs/expiring
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
# ✅ Should return beg with availableExtensions: [72h, 168h]

###

### Step 7: User Selects 72h from Popup
PUT {{baseUrl}}/api/begs/BEG_ID_FROM_STEP_1/extend
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "expiryHours": 72
}
# ✅ Extended to 72h - availableExtensions now only shows 168h

###

### Step 8: User Selects 7 Days from Popup
PUT {{baseUrl}}/api/begs/BEG_ID_FROM_STEP_1/extend
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "expiryHours": 168
}
# ✅ Extended to 7 days - no more availableExtensions

###

### Step 9: Someone Donates
POST {{baseUrl}}/api/donations/initialize
Authorization: Bearer {{loginUser2.response.body.data.accessToken}}
Content-Type: application/json

{
  "begId": "BEG_ID_FROM_STEP_1",
  "amount": 9000,
  "paymentMethod": "card"
}
# ✅ Donation initialized

###

### Step 10: Check Beg Status After Full Funding
GET {{baseUrl}}/api/begs/BEG_ID_FROM_STEP_1
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
# ✅ Expected: status = "funded"

###

### Step 11: Request Withdrawal
POST {{baseUrl}}/api/withdrawals/request
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "begId": "BEG_ID_FROM_STEP_1"
}
# ✅ Withdrawal created

###


###############################################
# SECTION 14: EDGE CASES
###############################################

### 14.1 Create Beg - No Auth (SHOULD FAIL)
POST {{baseUrl}}/api/begs
Content-Type: application/json

{
  "category": "food",
  "amountRequested": 1000,
  "expiryHours": 24
}
# ❌ Expected: 401 Unauthorized

###

### 14.2 Create Beg - SQL Injection Attempt
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "food'; DROP TABLE begs;--",
  "description": "'; DELETE FROM users;--",
  "amountRequested": 1000,
  "expiryHours": 24
}
# ✅ Expected: 400 - Invalid category (handled safely)

###

### 14.3 Create Beg - Unicode/Emoji in Description
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "food",
  "description": "Need food urgently 😢 please help 🙏",
  "amountRequested": 3000,
  "expiryHours": 24
}
# ✅ Expected: 201 Created

###

### 14.4 Create Beg - Very Large Amount
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "emergency",
  "amountRequested": 1000000,
  "expiryHours": 24
}
# ❌ Expected: 400 - Exceeds tier limit

