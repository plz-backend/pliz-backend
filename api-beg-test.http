###############################################
# PLIZ APP - BEG FEATURE COMPLETE TEST SUITE
# Categories | Trust Tiers | Cooldowns | Validation | Approval Workflow | Extend
###############################################
@baseUrl = http://localhost:3000
@user1Email = impactliveconsult@gmail.com
@user1Password = Test123!@#
@user2Email = chigoziegodwin93@gmail.com
@user2Password = Test123!@#
@user3Email = godwinchigozie93@gmail.com
@user3Password = Test123!@#
@adminEmail = admin@pliz.app
@adminPassword = Admin123!@#

###############################################
# SECTION 0: SETUP - LOGIN USERS
###############################################

### 0.1 Login User 1 (Donor/Requester)
# @name loginUser1
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{user1Email}}",
  "password": "{{user1Password}}"
}
# ✅ Expected: 200 OK

###

### 0.2 Login User 2 (Requester)
# @name loginUser2
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{user2Email}}",
  "password": "{{user2Password}}"
}
# ✅ Expected: 200 OK

###

### 0.3 Login User 3 (Requester)
# @name loginUser3
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{user3Email}}",
  "password": "{{user3Password}}"
}
# ✅ Expected: 200 OK

###

### 0.4 Login Admin
# @name loginAdmin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}
# ✅ Expected: 200 OK

###


###############################################
# SECTION 1: CATEGORY VALIDATION
###############################################

### 1.1 Get Available Categories
GET {{baseUrl}}/api/begs/categories
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
# ✅ Expected: 200 OK with categories list
# Should return: food, transport, rent, medical, education, emergency, other

###

### 1.2 Create Beg - Valid Category (no title, has description + expiryHours)
# @name createBegValidCategory
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "food",
  "description": "Lost my job last week and need help feeding my family this week",
  "amountRequested": 5000,
  "expiryHours": 24
}
# ✅ Expected: 201 Created
# {
#   "success": true,
#   "message": "Beg created successfully and pending approval.",
#   "data": {
#     "beg": {
#       "id": "...",
#       "description": "Lost my job last week and need help feeding my family this week",
#       "expiryHours": 24,
#       "approved": false,
#       "status": "active"
#     }
#   }
# }

###

### 1.3 Create Beg - Invalid Category (SHOULD FAIL)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "invalid_category",
  "amountRequested": 1000,
  "expiryHours": 24
}
# ❌ Expected: 400 - "Invalid category"

###

### 1.4 Create Beg - Missing Category (SHOULD FAIL)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "amountRequested": 1000,
  "expiryHours": 24
}
# ❌ Expected: 400 - "Category is required"

###


###############################################
# SECTION 2: DESCRIPTION VALIDATION
# (Title removed — description is now the main text field)
# Max: 40 words / 300 characters
###############################################

### 2.1 Create Beg - Valid Description (within 40 words)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "medical",
  "description": "Need urgent medical treatment and cannot afford the hospital bills right now. Any help is appreciated.",
  "amountRequested": 10000,
  "expiryHours": 72
}
# ✅ Expected: 201 Created

###

### 2.2 Create Beg - Description Over 40 Words (SHOULD FAIL)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "medical",
  "description": "I had an emergency surgery last week at the general hospital and the doctors are saying that I need to pay before they discharge me but I do not have any money right now because I just lost my job and my family depends on me for everything including food rent and school fees",
  "amountRequested": 15000,
  "expiryHours": 24
}
# ❌ Expected: 400 - "Description must be 40 words or less"

###

### 2.3 Create Beg - Description Over 300 Characters (SHOULD FAIL)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "emergency",
  "description": "This is a test description that exceeds three hundred characters to test the maximum character limit validation. We need to ensure that the system properly rejects descriptions that are too long. This helps us verify that our validation logic is working correctly for the Pliz platform.",
  "amountRequested": 20000,
  "expiryHours": 24
}
# ❌ Expected: 400 - "Description is too long (max 300 characters)"

###

### 2.4 Create Beg - No Description (Valid — description is optional)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "transport",
  "amountRequested": 500,
  "expiryHours": 24
}
# ✅ Expected: 201 Created (description is optional)

###

### 2.5 Create Beg - Empty Description (Valid)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "food",
  "description": "",
  "amountRequested": 3000,
  "expiryHours": 24
}
# ✅ Expected: 201 Created

###

### 2.6 Create Beg - Description Exactly 300 Characters (Valid)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "emergency",
  "description": "This is a test description that is exactly three hundred characters long to verify that the system properly handles descriptions at the maximum allowed length. This helps confirm that our validation logic works and users can utilize the full character allowance when providing details.",
  "amountRequested": 20000,
  "expiryHours": 72
}
# ✅ Expected: 201 Created (exactly 300 chars)

###


###############################################
# SECTION 3: EXPIRY HOURS VALIDATION
###############################################

### 3.1 Create Beg - 24 hours expiry
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "food",
  "description": "Need food urgently for my family today",
  "amountRequested": 3000,
  "expiryHours": 24
}
# ✅ Expected: 201 Created with expiryHours: 24

###

### 3.2 Create Beg - 72 hours expiry
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "rent",
  "description": "Rent is overdue and landlord is threatening to evict me",
  "amountRequested": 8000,
  "expiryHours": 72
}
# ✅ Expected: 201 Created with expiryHours: 72

###

### 3.3 Create Beg - 7 days (168 hours) expiry
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "medical",
  "description": "Hospital bill needs to be settled by end of week",
  "amountRequested": 9000,
  "expiryHours": 168
}
# ✅ Expected: 201 Created with expiryHours: 168

###

### 3.4 Create Beg - Invalid expiryHours (SHOULD FAIL)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "food",
  "amountRequested": 3000,
  "expiryHours": 48
}
# ❌ Expected: 400 - "Expiry must be 24 hours, 72 hours, or 7 days (168 hours)"

###

### 3.5 Create Beg - No expiryHours (defaults to 24)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "food",
  "amountRequested": 3000
}
# ✅ Expected: 201 Created with expiryHours: 24 (default)

###


###############################################
# SECTION 4: AMOUNT VALIDATION
###############################################

### 4.1 Create Beg - Valid Amount
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "food",
  "amountRequested": 5000,
  "expiryHours": 24
}
# ✅ Expected: 201 Created

###

### 4.2 Create Beg - Amount Below Minimum (SHOULD FAIL)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "food",
  "amountRequested": 50,
  "expiryHours": 24
}
# ❌ Expected: 400 - "Minimum amount is ₦100"

###

### 4.3 Create Beg - Missing Amount (SHOULD FAIL)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "food",
  "expiryHours": 24
}
# ❌ Expected: 400 - "Amount requested is required"

###

### 4.4 Create Beg - Invalid Amount Type (SHOULD FAIL)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "food",
  "amountRequested": "five thousand",
  "expiryHours": 24
}
# ❌ Expected: 400 - "Amount must be a number"

###

### 4.5 Create Beg - Amount Exceeds Tier Limit (SHOULD FAIL)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "rent",
  "amountRequested": 50000,
  "expiryHours": 24
}
# ❌ Expected: 400 - "Amount exceeds your tier limit of ₦10,000"

###

### 4.6 Create Beg - Zero Amount (SHOULD FAIL)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "food",
  "amountRequested": 0,
  "expiryHours": 24
}
# ❌ Expected: 400 - "Minimum amount is ₦100"

###

### 4.7 Create Beg - Negative Amount (SHOULD FAIL)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "food",
  "amountRequested": -5000,
  "expiryHours": 24
}
# ❌ Expected: 400 - Invalid amount

###


###############################################
# SECTION 5: EXTEND BEG
###############################################

### 5.1 Get Expiring Begs (Popup Trigger)
GET {{baseUrl}}/api/begs/expiring
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
# ✅ Expected: 200 OK
# {
#   "data": {
#     "hasExpiringBegs": true/false,
#     "begs": [
#       {
#         "id": "...",
#         "expiryHours": 24,
#         "expiresAt": "...",
#         "availableExtensions": [
#           { "hours": 72, "label": "72 hours" },
#           { "hours": 168, "label": "7 days" }
#         ]
#       }
#     ]
#   }
# }

###

### 5.2 Extend Beg - 24h → 72h
PUT {{baseUrl}}/api/begs/BEG_ID/extend
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "expiryHours": 72
}
# ✅ Expected: 200 OK
# {
#   "success": true,
#   "message": "Beg successfully extended to 72 hours!",
#   "data": {
#     "beg": { "expiryHours": 72, "expiresAt": "..." },
#     "availableExtensions": [{ "hours": 168, "label": "7 days" }]
#   }
# }

###

### 5.3 Extend Beg - 24h → 168h (7 days)
PUT {{baseUrl}}/api/begs/BEG_ID/extend
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "expiryHours": 168
}
# ✅ Expected: 200 OK - "Beg successfully extended to 7 days!"

###

### 5.4 Extend Beg - 72h → 168h (7 days)
PUT {{baseUrl}}/api/begs/BEG_ID/extend
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "expiryHours": 168
}
# ✅ Expected: 200 OK

###

### 5.5 Extend Beg - Downgrade Attempt (SHOULD FAIL)
PUT {{baseUrl}}/api/begs/BEG_ID/extend
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "expiryHours": 24
}
# ❌ Expected: 400 - "New expiry must be greater than current expiry"

###

### 5.6 Extend Beg Already at Max 168h (SHOULD FAIL)
PUT {{baseUrl}}/api/begs/MAX_EXPIRY_BEG_ID/extend
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "expiryHours": 168
}
# ❌ Expected: 400 - "New expiry must be greater than current expiry of 168 hours"

###

### 5.7 Extend Beg - Invalid expiryHours (SHOULD FAIL)
PUT {{baseUrl}}/api/begs/BEG_ID/extend
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "expiryHours": 48
}
# ❌ Expected: 400 - "Expiry must be 24 hours, 72 hours, or 7 days (168 hours)"

###

### 5.8 Extend Beg - Missing expiryHours (SHOULD FAIL)
PUT {{baseUrl}}/api/begs/BEG_ID/extend
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{}
# ❌ Expected: 400 - "Please select an expiry option"

###

### 5.9 Extend Another User's Beg (SHOULD FAIL)
PUT {{baseUrl}}/api/begs/ANOTHER_USERS_BEG_ID/extend
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "expiryHours": 72
}
# ❌ Expected: 403 - Unauthorized

###

### 5.10 Extend Cancelled Beg (SHOULD FAIL)
PUT {{baseUrl}}/api/begs/CANCELLED_BEG_ID/extend
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
Content-Type: application/json

{
  "expiryHours": 72
}
# ❌ Expected: 400 - "Can only extend active begs"

###

### 5.11 Extend Without Auth (SHOULD FAIL)
PUT {{baseUrl}}/api/begs/BEG_ID/extend
Content-Type: application/json

{
  "expiryHours": 72
}
# ❌ Expected: 401 Unauthorized

###

### 5.12 Extend - User on Cooldown (SHOULD STILL WORK)
# Cooldown only affects creating new begs, not extending
PUT {{baseUrl}}/api/begs/BEG_ID/extend
Authorization: Bearer {{loginUser2.response.body.data.accessToken}}
Content-Type: application/json

{
  "expiryHours": 72
}
# ✅ Expected: 200 OK (cooldown does NOT affect extend)

###


###############################################
# SECTION 6: COOLDOWN SYSTEM
###############################################

### 6.1 Create First Beg
# @name firstBeg
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser2.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "food",
  "description": "Testing cooldown system for the Pliz app",
  "amountRequested": 3000,
  "expiryHours": 24
}
# ✅ Expected: 201 Created

###

### 6.2 Create Second Beg Immediately (SHOULD FAIL - Cooldown)
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser2.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "food",
  "amountRequested": 2000,
  "expiryHours": 24
}
# ❌ Expected: 400 - Cooldown message (Tier 1: 48 hours cooldown)

###

### 6.3 Check Cooldown Status
GET {{baseUrl}}/api/begs/cooldown
Authorization: Bearer {{loginUser2.response.body.data.accessToken}}
# ✅ Expected: 200 OK
# {
#   "data": {
#     "is_on_cooldown": true,
#     "next_request_allowed_at": "...",
#     "hours_remaining": 47
#   }
# }

###

### 6.4 Reset Cooldown (Dev Only)
DELETE {{baseUrl}}/api/begs/dev/reset-cooldown
Authorization: Bearer {{loginUser2.response.body.data.accessToken}}
# ✅ Expected: 200 OK (only works in development)

###


###############################################
# SECTION 7: APPROVAL WORKFLOW
###############################################

### 7.1 Create Beg for Approval
# @name begForApproval
POST {{baseUrl}}/api/begs
Authorization: Bearer {{loginUser3.response.body.data.accessToken}}
Content-Type: application/json

{
  "category": "medical",
  "description": "Need urgent medical treatment and cannot afford the hospital bills",
  "amountRequested": 9000,
  "expiryHours": 72
}
# ✅ Expected: 201 Created with approved: false

###

### 7.2 Unapproved Beg NOT in Feed
GET {{baseUrl}}/api/begs?page=1&limit=20
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
# ✅ Expected: 200 OK - should NOT see unapproved beg

###

### 7.3 Admin Approves Beg
PATCH {{baseUrl}}/api/admin/begs/BEG_ID_FROM_7.1/approve
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}
# ✅ Expected: 200 OK
# {
#   "success": true,
#   "message": "Beg approved successfully",
#   "data": { "approved": true, "approved_at": "..." }
# }

###

### 7.4 Approved Beg NOW in Feed
GET {{baseUrl}}/api/begs?page=1&limit=20
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
# ✅ Expected: 200 OK - should NOW see approved beg

###

### 7.5 Get Beg by ID - Check Approval Fields
GET {{baseUrl}}/api/begs/BEG_ID_FROM_7.1
Authorization: Bearer {{loginUser1.response.body.data.accessToken}}
# ✅ Expected: 200 OK
# {
#   "data": {
#     "beg": {
#       "id": "...",
#       "description": "Need urgent medical treatment...",
#       "expiryHours": 72,
#       "approved": true,
#       "approved_at": "...",
#       "rejected_at": null,
#       "rejection_reason": null
#     }
#   }
# }

###


