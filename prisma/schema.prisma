generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")

}

// ============================================
// ENUMS
// ============================================

// Define UserRole enum BEFORE the User model
enum UserRole {
  user
  admin
  superadmin
}

// =====================================================
// MODELS
// =====================================================

model User {
  id                          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                       String    @unique @db.VarChar(255)
  username                    String    @unique @db.VarChar(50)
  passwordHash                String    @map("password_hash") @db.VarChar(255)  // 
  role                        UserRole  @default(user) // user, admin, superadmin
  isEmailVerified             Boolean   @default(false) @map("is_email_verified")
  emailVerifiedAt             DateTime? @map("email_verified_at") @db.Timestamp(6)
  isProfileComplete           Boolean   @default(false) @map("is_profile_complete") 

  // SUSPENSION FIELDS
  isSuspended            Boolean   @default(false) @map("is_suspended")
  suspensionReason       String?   @map("suspension_reason") @db.Text
  suspendedAt            DateTime? @map("suspended_at") @db.Timestamp(6)
  suspendedBy            String?   @map("suspended_by") @db.Uuid

  // INVESTIGATION FIELDS
  isUnderInvestigation   Boolean   @default(false) @map("is_under_investigation")
  investigationReason    String?   @map("investigation_reason") @db.Text
  investigationStartedAt DateTime? @map("investigation_started_at") @db.Timestamp(6)

  // OAuth fields
  googleId     String?  @unique @map("google_id") @db.VarChar(255)
  appleId      String?  @unique @map("apple_id") @db.VarChar(255)
  authProvider String   @default("email") @map("auth_provider") @db.VarChar(20) // email, google, apple
  avatar       String?  @db.Text

  // Transaction PIN (hashed, never store plaintext)
  transactionPinHash           String?   @map("transaction_pin_hash") @db.VarChar(255)
  transactionPinSetAt          DateTime? @map("transaction_pin_set_at") @db.Timestamp(6)
  transactionPinUpdatedAt      DateTime? @map("transaction_pin_updated_at") @db.Timestamp(6)
  transactionPinFailedAttempts Int       @default(0) @map("transaction_pin_failed_attempts")
  transactionPinLockedUntil    DateTime? @map("transaction_pin_locked_until") @db.Timestamp(6)
  
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  sessions          Session[]
  begs              Beg[]
  donations         Donation[]
  stats             UserStats?
  cooldown          Cooldown?
  trust             UserTrust?
  //KYC Verification
  verification      UserVerification?
  profile           UserProfile?
  reportsCreated    Report[]          @relation("ReporterReports")
  reportsReceived   Report[]          @relation("TargetUserReports")
  donorRank         DonorRank?
  notifications     Notification[]
  savedCards        SavedCard[]
  bankAccounts      BankAccount[]
  withdrawals       Withdrawal[]
  stories           Story[]
  reactions         Reaction[]
  // Support Relation
  supportTickets   SupportTicket[]  @relation("UserTickets")
  assignedTickets  SupportTicket[]  @relation("AssignedTickets")
  supportMessages  SupportMessage[] @relation("SentSupportMessages")
  supportChats     SupportChat[]

  // User avatar
  profileAvatar    UserAvatar? 
  
  // ADMIN ACTIONS
  adminActions      AdminAction[] @relation("AdminActions")
  targetedActions   AdminAction[] @relation("TargetedUser")

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([isSuspended])
  @@index([isUnderInvestigation])
  @@map("app_users")
  @@index([googleId])
  @@index([appleId])
}


// User Profile Model (REQUIRED - Basic Info)
// This is completed AFTER signup, BEFORE using the app

model UserProfile {
  userId       String   @id @map("user_id") @db.Uuid
  firstName    String   @map("first_name") @db.VarChar(100)
  middleName   String?  @map("middle_name") @db.VarChar(100)
  lastName     String   @map("last_name") @db.VarChar(100)
  displayName  String?  @map("display_name") @db.VarChar(150)
  phoneNumber  String   @map("phone_number") @db.VarChar(20)
  gender       String?  @map("gender") @db.VarChar(10)  // male or female
  dateOfBirth  DateTime @map("date_of_birth") @db.Date
  address      String?  @map("address") @db.VarChar(255)        // e.g. 12 Allen Avenue (optional)
  city         String  @map("city") @db.VarChar(100)
  state        String   @map("state") @db.VarChar(50)
  agreeToTerms Boolean  @default(false) @map("agree_to_terms")
  isAnonymous  Boolean  @default(false) @map("is_anonymous")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)  

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phoneNumber])
  @@map("user_profiles")
}


model UserAvatar {
  userId          String    @id @map("user_id") @db.Uuid

  // ============================================
  // AVATAR TYPE
  // Values: photo | initials | library
  // ============================================
  avatarType      String    @default("initials") @map("avatar_type") @db.VarChar(20)

  // ============================================
  // PHOTO UPLOAD
  // Set when avatarType = photo
  // ============================================
  avatarUrl       String?   @map("avatar_url") @db.Text

  // ============================================
  // INITIALS AVATAR
  // Set when avatarType = initials
  // ============================================
  avatarColor     String?   @default("#FF5733") @map("avatar_color") @db.VarChar(7)

  // ============================================
  // LIBRARY AVATAR
  // Set when avatarType = library
  // ============================================
  avatarLibraryId String?   @map("avatar_library_id") @db.VarChar(50)

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_avatars")
}

// Session

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  refreshToken String?   @map("refresh_token") @db.Text
  active       Boolean  @default(true)
  lastActive   DateTime @default(now()) @map("last_active") @db.Timestamp(6)
  expiresAt    DateTime @map("expires_at") @db.Timestamp(6)
  userAgent    String?  @map("user_agent") @db.Text
  browser      String?  @db.VarChar(50)
  os           String?  @db.VarChar(50)
  device       String?  @db.VarChar(50)
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  country      String?  @db.VarChar(100)
  city         String?  @db.VarChar(100)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp(6)  // ADDED


  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
  @@index([expiresAt])
  @@map("session_manager")
}



// Category Model - Beg categories (food, transport, rent, etc.)
model Category {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(50) // e.g., "Food"
  slug        String   @unique @db.VarChar(50) // e.g., "food"
  description String?  @db.Text
  icon        String?  @db.VarChar(50) // emoji or icon name
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  begs Beg[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("categories")
}

// Update the Beg model to use categoryId instead of category string

model Beg {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  categoryId      String    @map("category_id") @db.Uuid
  description     String?   @db.VarChar(300) // Max ~40 words (300 chars)
  amountRequested Decimal   @map("amount_requested") @db.Decimal(12, 2)
  amountRaised    Decimal   @default(0) @map("amount_raised") @db.Decimal(12, 2)
  status          String    @default("active") @db.VarChar(20)
  approved        Boolean   @default(false)
  approvedAt      DateTime? @map("approved_at") @db.Timestamp(6)
  approvedBy      String?   @map("approved_by") @db.Uuid
  rejectedAt      DateTime? @map("rejected_at") @db.Timestamp(6)
  rejectedBy      String?   @map("rejected_by") @db.Uuid
  rejectionReason String?   @map("rejection_reason") @db.Text
  expiryHours     Int       @default(24) @map("expiry_hours") // 24, 48, or 168 (7 days)
  expiresAt       DateTime  @map("expires_at") @db.Timestamp(6)
  payoutRequested Boolean   @default(false) @map("payout_requested")
  isAnonymous     Boolean   @default(false) @map("is_anonymous")
  isWithdrawn     Boolean   @default(false) @map("is_withdrawn")
  withdrawnAt     DateTime? @map("withdrawn_at") @db.Timestamp(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  // Media fields
  mediaType       String?   @default("text") @map("media_type") @db.VarChar(10)
  mediaUrl        String?   @map("media_url") @db.Text

  // Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  donations   Donation[]
  withdrawals Withdrawal[]
  reports     Report[]
  reactions  Reaction[]   

  @@index([userId])
  @@index([categoryId])
  @@index([status])
  @@index([approved])
  @@index([expiresAt])
  @@index([isWithdrawn])
  @@map("begs")
}

//
//Donation Model
//Tracks all donations made to begs
//
model Donation {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  begId            String   @map("request_id") @db.Uuid
  donorId          String?  @map("donor_id") @db.Uuid // Nullable for deleted users
  amount           Decimal  @db.Decimal(12, 2) // Must be > 0 enforced in app
  isAnonymous      Boolean  @default(false) @map("is_anonymous")
  paymentMethod    String?  @map("payment_method") @db.VarChar(30)
  paymentReference String?  @unique @map("payment_reference") @db.VarChar(255)
  status           String   @default("success") @db.VarChar(20) // Values: success, failed, reversed
  ipAddress        String?   @map("ip_address") @db.VarChar(45)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  

  // Relations
  beg              Beg               @relation(fields: [begId], references: [id], onDelete: Cascade)
  donor            User?             @relation(fields: [donorId], references: [id], onDelete: SetNull)
  gratitudeMessage GratitudeMessage?
  reactions        Reaction[]  

  
  @@index([begId])
  @@index([donorId])
  @@index([status])
  @@index([ipAddress, createdAt])
  @@index([createdAt])
  @@map("donations")
}

//Admin Action Model
//Logs all administrative actions
// Admin Action Log
model AdminAction {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId     String   @map("admin_id") @db.Uuid
  actionType  String   @map("action_type") @db.VarChar(50)
  targetType  String?  @map("target_type") @db.VarChar(50) // user, beg, withdrawal, etc.
  targetId    String?  @map("target_id") @db.Uuid
  description String   @db.Text
  metadata    Json?    @db.JsonB
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  // Relations
  admin       User     @relation("AdminActions", fields: [adminId], references: [id], onDelete: Cascade)
  targetUser  User?    @relation("TargetedUser", fields: [targetId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([actionType])
  @@index([targetType])
  @@index([createdAt])
  @@map("admin_actions")
}

//Report Model
//User-generated reports for flagging abuse

model Report {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporterId   String?  @map("reporter_id") @db.Uuid
  targetUserId String?  @map("target_user_id") @db.Uuid
  begId        String?  @map("request_id") @db.Uuid
  reason       String?  @db.Text
  resolved     Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  // Relations
  reporter   User? @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: SetNull)
  targetUser User? @relation("TargetUserReports", fields: [targetUserId], references: [id], onDelete: SetNull)
  beg        Beg?  @relation(fields: [begId], references: [id], onDelete: SetNull)

  @@index([reporterId])
  @@index([targetUserId])
  @@index([begId])
  @@index([resolved])
  @@map("reports")
}

//Gratitude Message Model
//Thank you messages from beg creators to donors

model GratitudeMessage {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  donationId        String    @unique @map("donation_id") @db.Uuid
  messageType       Int       @default(1) @map("message_type") @db.SmallInt  // 1=text, 2=audio (coming soon)
  content           String?   @db.Text
  donorReplyAllowed Boolean   @default(true) @map("donor_reply_allowed")
  donorReplied      Boolean   @default(false) @map("donor_replied")
  donorReply        String?   @map("donor_reply") @db.Text
  donorRepliedAt    DateTime? @map("donor_replied_at") @db.Timestamp(6)
  expiresAt         DateTime? @map("expires_at") @db.Timestamp(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  donation          Donation  @relation(fields: [donationId], references: [id], onDelete: Cascade)

  @@index([donationId])
  @@map("gratitude_messages")
}

model UserStats {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String   @unique @map("user_id") @db.Uuid
  requestsCount       Int      @default(0) @map("requests_count")
  totalReceived       Decimal  @default(0) @map("total_received") @db.Decimal(12, 2)
  totalWithdrawn      Decimal  @default(0) @map("total_withdrawn") @db.Decimal(12, 2) // NEW
  availableBalance    Decimal  @default(0) @map("available_balance") @db.Decimal(12, 2) // NEW
  totalDonated        Decimal  @default(0) @map("total_donated") @db.Decimal(12, 2)
  abuseFlags          Int      @default(0) @map("abuse_flags")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_stats")
}

//User Trust Model
//Trust tier and eligibility tracking

model UserTrust {
  userId        String    @id @map("user_id") @db.Uuid
  trustTier     Int       @default(1) @map("trust_tier") @db.SmallInt // Values: 1, 2, 3
  lastRequestAt DateTime? @map("last_request_at") @db.Timestamp(6)

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_trust")
}

//Cooldown Model
//Request cooldown periods for users

model Cooldown {
  userId               String   @id @map("user_id") @db.Uuid
  nextRequestAllowedAt DateTime @map("next_request_allowed_at") @db.Timestamp(6)

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([nextRequestAllowedAt])
  @@map("cooldowns")
}

// User Verification Model (KYC)
// Done AFTER profile completion
// Required before creating a beg
model UserVerification {
  userId              String    @id @map("user_id") @db.Uuid

  // ============================================
  // VERIFICATION TYPE — nin | passport
  // ============================================
  verificationType     String?   @map("verification_type") @db.VarChar(20)

  // ============================================
  // NIN FIELDS
  // ninDocumentType: slip | card
  // slip = front only
  // card = front + back
  // ============================================
  nin                  String?   @map("nin") @db.VarChar(11)
  ninDocumentType      String?   @map("nin_document_type") @db.VarChar(10)
  ninMiddleName        String?   @map("nin_middle_name") @db.VarChar(100)
  ninStateOfOrigin     String?   @map("nin_state_of_origin") @db.VarChar(100)
  ninLGA               String?   @map("nin_lga") @db.VarChar(100)
  ninEnrollmentDate    DateTime? @map("nin_enrollment_date") @db.Timestamp(6)
  ninFrontUrl          String?   @map("nin_front_url") @db.Text
  ninBackUrl           String?   @map("nin_back_url") @db.Text
  ninVerified          Boolean   @default(false) @map("nin_verified")
  ninVerifiedAt        DateTime? @map("nin_verified_at") @db.Timestamp(6)


  // ============================================
  // PASSPORT FIELDS
  // ============================================
  passportNumber       String?   @map("passport_number") @db.VarChar(20)
  passportMiddleName   String?   @map("passport_middle_name") @db.VarChar(100)
  passportPlaceOfBirth String?   @map("passport_place_of_birth") @db.VarChar(100)
  passportIssueDate    DateTime? @map("passport_issue_date") @db.Timestamp(6)
  passportExpiry       DateTime? @map("passport_expiry") @db.Timestamp(6)
  passportPlaceOfIssue String?   @map("passport_place_of_issue") @db.VarChar(100)
  passportBiodataUrl   String?   @map("passport_biodata_url") @db.Text
  passportVerified     Boolean   @default(false) @map("passport_verified")
  passportVerifiedAt   DateTime? @map("passport_verified_at") @db.Timestamp(6)

  // ============================================
  // PHONE VERIFICATION (OTP)
  // Phone number comes from UserProfile
  // Verified here via OTP before identity check
  // ============================================
  phoneVerified            Boolean   @default(false) @map("phone_verified")
  phoneVerifiedAt          DateTime? @map("phone_verified_at") @db.Timestamp(6)
  phoneOtp                 String?   @map("phone_otp") @db.VarChar(255)
  // ↑ stores SendChamp reference (not the OTP itself)
  phoneOtpSentAt           DateTime? @map("phone_otp_sent_at") @db.Timestamp(6)
  // ↑ stores when OTP was sent — used for cooldown + expiry
  phoneVerificationChannel String?   @map("phone_verification_channel") @db.VarChar(20)
  // ↑ sms | whatsapp

  // ============================================
  // FACE LIVENESS
  // ============================================
  faceLivenessUrl      String?   @map("face_liveness_url") @db.Text
  faceLivenessPassed   Boolean   @default(false) @map("face_liveness_passed")
  faceLivenessPassedAt DateTime? @map("face_liveness_passed_at") @db.Timestamp(6)
  faceLivenessScore    Float?    @map("face_liveness_score")

  // ============================================
  // DOCUMENT AUTHENTICITY
  // ============================================
  documentVerified     Boolean   @default(false) @map("document_verified")
  documentVerifiedAt   DateTime? @map("document_verified_at") @db.Timestamp(6)


  // ============================================
  // OVERALL STATUS
  // pending | document_uploaded | liveness_passed
  // under_review | verified | rejected
  // ============================================
  status               String    @default("pending") @map("status") @db.VarChar(20)
  isVerified           Boolean   @default(false) @map("is_verified")
  verifiedAt           DateTime? @map("verified_at") @db.Timestamp(6)


  // ============================================
  // REJECTION
  // ============================================
  rejectionReason      String?   @map("rejection_reason") @db.Text
  rejectedAt           DateTime? @map("rejected_at") @db.Timestamp(6)
  rejectedBy           String?   @map("rejected_by") @db.Uuid


   // ============================================
  // ATTEMPTS (max 3)
  // ============================================
  attemptCount         Int       @default(0) @map("attempt_count")
  lastAttemptAt        DateTime? @map("last_attempt_at") @db.Timestamp(6)


  // ============================================
  // PROVIDER
  // ============================================
  verificationProvider String?   @map("verification_provider") @db.VarChar(100)
  providerReference    String?   @map("provider_reference") @db.VarChar(255)
  providerResponse     Json?     @map("provider_response") @db.JsonB

  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([isVerified])
  @@index([verificationType])
  @@map("user_verifications")
}

// ADD new DonorRank model:
model DonorRank {
  userId        String    @id @map("user_id") @db.Uuid
  rankName      String    @default("Tryer") @map("rank_name") @db.VarChar(50)
  totalDonated  Decimal   @default(0) @map("total_donated") @db.Decimal(12, 2)
  donationCount Int       @default(0) @map("donation_count")
  streakDays    Int       @default(0) @map("streak_days")
  lastDonatedAt DateTime? @map("last_donated_at") @db.Timestamp(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("donor_ranks")
}

// ADD Notification model:
model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50)   // beg_funded | donation_received | message_received | donor_reply
  title     String   @db.VarChar(255)
  body      String   @db.Text
  data      Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}


model SavedCard {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  authorizationCode String   @unique @map("authorization_code") @db.VarChar(255)
  cardType          String   @map("card_type") @db.VarChar(20) // visa, mastercard
  last4             String   @db.VarChar(4)
  expMonth          String   @map("exp_month") @db.VarChar(2)
  expYear           String   @map("exp_year") @db.VarChar(4)
  bank              String?  @db.VarChar(100)
  isDefault         Boolean  @default(false) @map("is_default")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isDefault])
  @@map("saved_cards")
}

model BankAccount {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  accountNumber String    @map("account_number") @db.VarChar(10)
  accountName   String    @map("account_name") @db.VarChar(255)
  bankCode      String    @map("bank_code") @db.VarChar(10)
  bankName      String    @map("bank_name") @db.VarChar(100)
  isVerified    Boolean   @default(false) @map("is_verified")
  isDefault     Boolean   @default(false) @map("is_default")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  // Relations
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  withdrawals   Withdrawal[]

  @@unique([userId, accountNumber])
  @@index([userId])
  @@index([isDefault])
  @@map("bank_accounts")
}


model Withdrawal {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  begId             String    @map("beg_id") @db.Uuid
  bankAccountId     String    @map("bank_account_id") @db.Uuid
  amountRequested   Decimal   @map("amount_requested") @db.Decimal(12, 2)
  companyFee        Decimal   @map("company_fee") @db.Decimal(12, 2) // 5%
  vatFee            Decimal   @map("vat_fee") @db.Decimal(12, 2) // 7.5% of companyFee
  totalFees         Decimal   @map("total_fees") @db.Decimal(12, 2) // 5.375% effective total
  amountToReceive   Decimal   @map("amount_to_receive") @db.Decimal(12, 2)
  transferReference String?   @unique @map("transfer_reference") @db.VarChar(255)
  status            String    @default("pending") @db.VarChar(20) // pending, processing, completed, failed
  failureReason     String?   @map("failure_reason") @db.Text
  autoProcessed     Boolean   @default(false) @map("auto_processed") // NEW
  processedAt       DateTime? @map("processed_at") @db.Timestamp(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  // Relations
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  beg               Beg          @relation(fields: [begId], references: [id], onDelete: Cascade)
  bankAccount       BankAccount  @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([begId])
  @@index([status])
  @@index([createdAt])
  @@map("withdrawals")
}


model Story {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  content        String    @db.VarChar(500)
  isApproved     Boolean   @default(false) @map("is_approved")
  approvedAt     DateTime? @map("approved_at") @db.Timestamp(6)
  approvedBy     String?   @map("approved_by") @db.Uuid
  rejectedAt     DateTime? @map("rejected_at") @db.Timestamp(6)
  rejectedBy     String?   @map("rejected_by") @db.Uuid
  rejectionReason String?  @map("rejection_reason") @db.Text
  isVisible      Boolean   @default(true) @map("is_visible")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isApproved])
  @@index([isVisible])
  @@index([createdAt])
  @@map("stories")
}

//Reactions
model Reaction {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  emoji      String   @map("emoji") @db.VarChar(10)

  // Either begId or donationId — not both
  begId      String?  @map("beg_id") @db.Uuid
  donationId String?  @map("donation_id") @db.Uuid

  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  // Relations
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  beg        Beg?      @relation(fields: [begId], references: [id], onDelete: Cascade)
  donation   Donation? @relation(fields: [donationId], references: [id], onDelete: Cascade)

  // ONE reaction per user per beg OR per donation
  @@unique([userId, begId])
  @@unique([userId, donationId])
  @@index([begId])
  @@index([donationId])
  @@index([userId])
  @@map("reactions")
}


// ============================================
// SUPPORT TICKET
// ============================================
model SupportTicket {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  ticketNumber String    @unique @map("ticket_number") @db.VarChar(20)
  subject      String    @map("subject") @db.VarChar(255)
  category     String    @map("category") @db.VarChar(50)
  // Values: account | payment | beg | donation | kyc | technical | other
  contactEmail String    @map("contact_email") @db.VarChar(255) // ← user's preferred contact email
  status       String    @default("open") @map("status") @db.VarChar(20)
  // Values: open | in_progress | waiting_user | resolved | closed
  priority     String    @default("normal") @map("priority") @db.VarChar(20)
  // Values: low | normal | high | urgent
  assignedTo   String?   @map("assigned_to") @db.Uuid
  resolvedAt   DateTime? @map("resolved_at") @db.Timestamp(6)
  closedAt     DateTime? @map("closed_at") @db.Timestamp(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  user         User              @relation("UserTickets", fields: [userId], references: [id], onDelete: Cascade)
  assignee     User?             @relation("AssignedTickets", fields: [assignedTo], references: [id], onDelete: SetNull)
  messages     SupportMessage[]

  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([assignedTo])
  @@index([createdAt])
  @@map("support_tickets")
}

// ============================================
// SUPPORT MESSAGE
// ============================================
model SupportMessage {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId   String   @map("ticket_id") @db.Uuid
  senderId   String?  @map("sender_id") @db.Uuid  // null = AI message
  senderType String   @map("sender_type") @db.VarChar(20)
  // Values: user | agent | ai
  content    String   @map("content") @db.Text
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  // Relations
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender     User?         @relation("SentSupportMessages", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([senderId])
  @@index([createdAt])
  @@map("support_messages")
}

// ============================================
// SUPPORT CHAT SESSION (AI Chat)
// ============================================
model SupportChat {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  sessionId String   @unique @map("session_id") @db.VarChar(100)
  status    String   @default("active") @map("status") @db.VarChar(20)
  // Values: active | escalated | closed
  ticketId  String?  @map("ticket_id") @db.Uuid  // set when escalated to human
  messages  Json     @default("[]") @map("messages") @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("support_chats")
}



