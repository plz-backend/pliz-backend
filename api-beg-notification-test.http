###############################################
# SECTION 11: GRATITUDE MESSAGES
###############################################

### 11.1 Recipient Sends Thank You
# @name sendGratitude
POST {{baseUrl}}/api/donations/{{initDonation.response.body.data.donation_id}}/gratitude
Authorization: Bearer {{loginRecipient.response.body.data.accessToken}}
Content-Type: application/json

{
  "content": "Thank you so much for your generous donation! This will really help me get the medical treatment I need. I'm truly grateful! 🙏",
  "donorReplyAllowed": true
}

# ✅ Expected: 201 Created
# {
#   "success": true,
#   "message": "Gratitude message sent successfully",
#   "data": {
#     "message": {
#       "id": "...",
#       "content": "Thank you so much!...",
#       "donor_reply_allowed": true,
#       "donor_replied": false,
#       "expires_at": "..."
#     }
#   }
# }

###

### 11.2 Send Gratitude - No Reply Allowed
POST {{baseUrl}}/api/donations/{{initDonation.response.body.data.donation_id}}/gratitude
Authorization: Bearer {{loginRecipient.response.body.data.accessToken}}
Content-Type: application/json

{
  "content": "Thank you! No need to reply.",
  "donorReplyAllowed": false
}

# ✅ Expected: 201 Created - expires_at should be null

###

### 11.3 Send Gratitude - Already Sent
POST {{baseUrl}}/api/donations/{{initDonation.response.body.data.donation_id}}/gratitude
Authorization: Bearer {{loginRecipient.response.body.data.accessToken}}
Content-Type: application/json

{
  "content": "Another thank you",
  "donorReplyAllowed": true
}

# ❌ Expected: 400 - "Gratitude message already sent"

###

### 11.4 Send Gratitude - Unauthorized (Donor Trying)
POST {{baseUrl}}/api/donations/{{initDonation.response.body.data.donation_id}}/gratitude
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}
Content-Type: application/json

{
  "content": "Donor trying to send gratitude",
  "donorReplyAllowed": true
}

# ❌ Expected: 403 - "Unauthorized"

###

### 11.5 Send Gratitude - Empty Content
POST {{baseUrl}}/api/donations/{{initDonation.response.body.data.donation_id}}/gratitude
Authorization: Bearer {{loginRecipient.response.body.data.accessToken}}
Content-Type: application/json

{
  "content": "",
  "donorReplyAllowed": true
}

# ❌ Expected: 400 - "Message content is required"

###

### 11.6 Send Gratitude - Content Too Long (>500 chars)
POST {{baseUrl}}/api/donations/{{initDonation.response.body.data.donation_id}}/gratitude
Authorization: Bearer {{loginRecipient.response.body.data.accessToken}}
Content-Type: application/json

{
  "content": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum. Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.",
  "donorReplyAllowed": true
}

# ❌ Expected: 400 - "Message cannot exceed 500 characters"

###

### 11.7 Send Gratitude - No Auth
POST {{baseUrl}}/api/donations/{{initDonation.response.body.data.donation_id}}/gratitude
Content-Type: application/json

{
  "content": "Thank you!",
  "donorReplyAllowed": true
}

# ❌ Expected: 401 Unauthorized

###

