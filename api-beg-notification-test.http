###############################################
# PLIZ APP - COMPLETE DONATION TEST SUITE
# Donations | Trust Engine | Messages | Notifications | Ranks
###############################################

@baseUrl = http://localhost:3000
@donorEmail = impactliveconsult@gmail.com
@recipientEmail = chigoziegodwin93@gmail.com
@thirdUserEmail = godwinchigozie93@gmail.com
@testPassword = Test123!@#

###############################################
# SECTION 0: SETUP - LOGIN ALL TEST USERS
###############################################

### 0.1 Login Donor (User 1)
# @name loginDonor
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{donorEmail}}",
  "password": "{{testPassword}}"
}

# ✅ Expected: 200 OK
# {
#   "success": true,
#   "data": {
#     "accessToken": "eyJ...",
#     "user": { "id": "...", "email": "impactliveconsult@gmail.com" }
#   }
# }

###

### 0.2 Login Recipient (User 2)
# @name loginRecipient
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{recipientEmail}}",
  "password": "{{testPassword}}"
}

# ✅ Expected: 200 OK

###

### 0.3 Login Third User
# @name loginThirdUser
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{thirdUserEmail}}",
  "password": "{{testPassword}}"
}

# ✅ Expected: 200 OK

###

### 0.4 Get Active Begs (To Get Test IDs)
# @name getActiveBegs
GET {{baseUrl}}/api/begs?status=active&limit=5
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}

# Copy a beg ID for testing

###

###############################################
# SECTION 1: DONATION INITIALIZATION - SUCCESS CASES
###############################################

### 1.1 Initialize Donation - Success
# @name initDonation
POST {{baseUrl}}/api/donations/initialize
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}
Content-Type: application/json

{
  "begId": "1d3379b8-5727-46c4-b170-4f83afd71ff8",
  "amount": 5000,
  "isAnonymous": false,
  "paymentMethod": "card"
}

# ✅ Expected: 201 Created
# {
#   "success": true,
#   "message": "Please complete payment",
#   "data": {
#     "donation_id": "...",
#     "amount": 5000,
#     "payment_reference": "DON-...",
#     "payment_url": "https://checkout.paystack.com/...",
#     "quick_amounts": [1000, 2000, 3000, 5000]
#   }
# }
# → Open payment_url in browser to complete payment

###

### 1.2 Initialize Anonymous Donation
POST {{baseUrl}}/api/donations/initialize
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}
Content-Type: application/json

{
  "begId": "1d3379b8-5727-46c4-b170-4f83afd71ff8",
  "amount": 3000,
  "isAnonymous": true,
  "paymentMethod": "card"
}

# ✅ Expected: 201 Created - donor will show as "Anonymous"

###

### 1.3 Initialize with Transfer Payment Method
POST {{baseUrl}}/api/donations/initialize
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}
Content-Type: application/json

{
  "begId": "1d3379b8-5727-46c4-b170-4f83afd71ff8",
  "amount": 2000,
  "isAnonymous": false,
  "paymentMethod": "transfer"
}

# ✅ Expected: 201 Created

###

### 1.4 Initialize with USSD Payment Method
POST {{baseUrl}}/api/donations/initialize
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}
Content-Type: application/json

{
  "begId": "1d3379b8-5727-46c4-b170-4f83afd71ff8",
  "amount": 1500,
  "isAnonymous": false,
  "paymentMethod": "ussd"
}

# ✅ Expected: 201 Created

###

### 1.5 Initialize - Amount Exceeds Remaining (Auto-adjusted)
POST {{baseUrl}}/api/donations/initialize
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}
Content-Type: application/json

{
  "begId": "1d3379b8-5727-46c4-b170-4f83afd71ff8",
  "amount": 999999,
  "isAnonymous": false,
  "paymentMethod": "card"
}

# ✅ Expected: 201 Created - amount adjusted to remaining balance

###

###############################################
# SECTION 2: DONATION INITIALIZATION - VALIDATION FAILURES
###############################################

### 2.1 Initialize - Missing begId
POST {{baseUrl}}/api/donations/initialize
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}
Content-Type: application/json

{
  "amount": 5000,
  "isAnonymous": false,
  "paymentMethod": "card"
}

# ❌ Expected: 400 - "begId is required"

###

### 2.2 Initialize - Invalid Amount Type
POST {{baseUrl}}/api/donations/initialize
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}
Content-Type: application/json

{
  "begId": "1d3379b8-5727-46c4-b170-4f83afd71ff8",
  "amount": "five thousand",
  "isAnonymous": false,
  "paymentMethod": "card"
}

# ❌ Expected: 400 - "amount must be a number"

###

### 2.3 Initialize - Amount Below Minimum
POST {{baseUrl}}/api/donations/initialize
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}
Content-Type: application/json

{
  "begId": "1d3379b8-5727-46c4-b170-4f83afd71ff8",
  "amount": 50,
  "isAnonymous": false,
  "paymentMethod": "card"
}

# ❌ Expected: 400 - "Minimum donation is ₦100"

###

### 2.4 Initialize - Amount Above Maximum
POST {{baseUrl}}/api/donations/initialize
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}
Content-Type: application/json

{
  "begId": "1d3379b8-5727-46c4-b170-4f83afd71ff8",
  "amount": 150000,
  "isAnonymous": false,
  "paymentMethod": "card"
}

# ❌ Expected: 400 - "Maximum donation is ₦100,000"

###

### 2.5 Initialize - Invalid Payment Method
POST {{baseUrl}}/api/donations/initialize
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}
Content-Type: application/json

{
  "begId": "1d3379b8-5727-46c4-b170-4f83afd71ff8",
  "amount": 5000,
  "isAnonymous": false,
  "paymentMethod": "bitcoin"
}

# ❌ Expected: 400 - "paymentMethod must be card, transfer or ussd"

###

### 2.6 Initialize - Beg Not Found
POST {{baseUrl}}/api/donations/initialize
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}
Content-Type: application/json

{
  "begId": "00000000-0000-0000-0000-000000000000",
  "amount": 5000,
  "isAnonymous": false,
  "paymentMethod": "card"
}

# ❌ Expected: 404 - "Beg not found"

###

### 2.7 Initialize - No Authentication
POST {{baseUrl}}/api/donations/initialize
Content-Type: application/json

{
  "begId": "1d3379b8-5727-46c4-b170-4f83afd71ff8",
  "amount": 5000,
  "isAnonymous": false,
  "paymentMethod": "card"
}

# ❌ Expected: 401 Unauthorized

###

###############################################
# SECTION 3: TRUST ENGINE - SELF DONATION BLOCKING
###############################################

### 3.1 Self-Donation Attempt (BLOCKED)
POST {{baseUrl}}/api/donations/initialize
Authorization: Bearer {{loginRecipient.response.body.data.accessToken}}
Content-Type: application/json

{
  "begId": "1d3379b8-5727-46c4-b170-4f83afd71ff8",
  "amount": 5000,
  "isAnonymous": false,
  "paymentMethod": "card"
}

# ❌ Expected: 403 Forbidden
# {
#   "success": false,
#   "message": "You cannot donate to your own request"
# }

# ✅ Check logs: Should see "self_donation_attempt"
# grep "self_donation_attempt" logs/combined.log

###

### 3.2 Different User Donating (ALLOWED)
POST {{baseUrl}}/api/donations/initialize
Authorization: Bearer {{loginThirdUser.response.body.data.accessToken}}
Content-Type: application/json

{
  "begId": "1d3379b8-5727-46c4-b170-4f83afd71ff8",
  "amount": 2000,
  "isAnonymous": false,
  "paymentMethod": "card"
}

# ✅ Expected: 201 Created

###

###############################################
# SECTION 4: TRUST ENGINE - LARGE DONATIONS
###############################################

### 4.1 Exactly ₦50,000 (Boundary - Not Logged)
POST {{baseUrl}}/api/donations/initialize
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}
Content-Type: application/json

{
  "begId": "1d3379b8-5727-46c4-b170-4f83afd71ff8",
  "amount": 50000,
  "isAnonymous": false,
  "paymentMethod": "card"
}

# ✅ Expected: 201 Created
# ✅ No "large_donation_attempt" log

###

### 4.2 Large Donation ₦75,000 (LOGGED BUT ALLOWED)
POST {{baseUrl}}/api/donations/initialize
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}
Content-Type: application/json

{
  "begId": "1d3379b8-5727-46c4-b170-4f83afd71ff8",
  "amount": 75000,
  "isAnonymous": false,
  "paymentMethod": "card"
}

# ✅ Expected: 201 Created (MVP allows, but logs)
# ✅ Check logs: Should see "large_donation_attempt"
# grep "large_donation_attempt" logs/combined.log

###

### 4.3 Maximum Allowed ₦100,000
POST {{baseUrl}}/api/donations/initialize
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}
Content-Type: application/json

{
  "begId": "1d3379b8-5727-46c4-b170-4f83afd71ff8",
  "amount": 100000,
  "isAnonymous": false,
  "paymentMethod": "card"
}

# ✅ Expected: 201 Created
# ✅ Check logs: Should see "large_donation_attempt"

###

###############################################
# SECTION 5: TRUST ENGINE - ABUSE FLAGS
###############################################

### 5.1 Setup - Flag User with 3 Abuse Flags
# SQL: UPDATE user_stats SET abuse_flags = 3 WHERE user_id = 'DONOR_USER_ID';

###

### 5.2 User with 3 Abuse Flags (LOGGED BUT ALLOWED)
POST {{baseUrl}}/api/donations/initialize
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}
Content-Type: application/json

{
  "begId": "1d3379b8-5727-46c4-b170-4f83afd71ff8",
  "amount": 2000,
  "isAnonymous": false,
  "paymentMethod": "card"
}

# ✅ Expected: 201 Created (flags < 5, so allowed)
# ✅ Check logs: Should see "donation_attempt_with_flags"
# grep "donation_attempt_with_flags" logs/combined.log

###

### 5.3 Setup - Increase Flags to 5 (Threshold)
# SQL: UPDATE user_stats SET abuse_flags = 5 WHERE user_id = 'DONOR_USER_ID';

###

### 5.4 User with 5+ Abuse Flags (BLOCKED)
POST {{baseUrl}}/api/donations/initialize
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}
Content-Type: application/json

{
  "begId": "1d3379b8-5727-46c4-b170-4f83afd71ff8",
  "amount": 2000,
  "isAnonymous": false,
  "paymentMethod": "card"
}

# ❌ Expected: 403 Forbidden
# {
#   "success": false,
#   "message": "Your account has been flagged. Please contact support."
# }

###

### 5.5 Cleanup - Reset Abuse Flags
# SQL: UPDATE user_stats SET abuse_flags = 0 WHERE user_id = 'DONOR_USER_ID';

###

###############################################
# SECTION 6: PAYMENT VERIFICATION
###############################################

### 6.1 Verify Payment Manually (After Paystack Payment)
# @name verifyPayment
POST {{baseUrl}}/api/donations/verify?reference={{initDonation.response.body.data.payment_reference}}
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}

# ✅ Expected: 200 OK - Donation status updated to 'success'

###

### 6.2 Verify Payment - Invalid Reference
POST {{baseUrl}}/api/donations/verify?reference=INVALID_REF
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}

# ❌ Expected: 400 or 404 - Invalid reference

###

### 6.3 Verify Payment - Already Verified (Idempotent)
POST {{baseUrl}}/api/donations/verify?reference={{initDonation.response.body.data.payment_reference}}
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}

# ✅ Expected: 200 OK - Returns existing donation

###

