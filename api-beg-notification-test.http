###############################################
# SECTION 18: COMPLETE END-TO-END JOURNEY
###############################################

### Step 1: Get Available Begs
GET {{baseUrl}}/api/begs?status=active&limit=5
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}

###

### Step 2: Initialize Donation
# @name e2eDonation
POST {{baseUrl}}/api/donations/initialize
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}
Content-Type: application/json

{
  "begId": "1d3379b8-5727-46c4-b170-4f83afd71ff8",
  "amount": 3000,
  "isAnonymous": false,
  "paymentMethod": "card"
}

# → Open payment_url in browser, complete payment

###

### Step 3: Check Donor Rank Updated
GET {{baseUrl}}/api/donations/my-rank
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}

###

### Step 4: Check Recipient Notifications
GET {{baseUrl}}/api/notifications
Authorization: Bearer {{loginRecipient.response.body.data.accessToken}}

###

### Step 5: Recipient Sends Gratitude
POST {{baseUrl}}/api/donations/{{e2eDonation.response.body.data.donation_id}}/gratitude
Authorization: Bearer {{loginRecipient.response.body.data.accessToken}}
Content-Type: application/json

{
  "content": "This really saved me today! Thank you from the bottom of my heart 🙏",
  "donorReplyAllowed": true
}

###

### Step 6: Donor Checks Notifications
GET {{baseUrl}}/api/notifications
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}

###

### Step 7: Donor Reads Message
GET {{baseUrl}}/api/donations/messages/received
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}

###

### Step 8: Donor Replies
POST {{baseUrl}}/api/donations/{{e2eDonation.response.body.data.donation_id}}/reply
Authorization: Bearer {{loginDonor.response.body.data.accessToken}}
Content-Type: application/json

{
  "reply": "You're very welcome! Wishing you all the best 🌟"
}

###

### Step 9: Recipient Checks Notifications Again
GET {{baseUrl}}/api/notifications
Authorization: Bearer {{loginRecipient.response.body.data.accessToken}}

###

### Step 10: Recipient Reads Reply
GET {{baseUrl}}/api/donations/messages/sent
Authorization: Bearer {{loginRecipient.response.body.data.accessToken}}

###

### Step 11: Mark All Notifications Read
PATCH {{baseUrl}}/api/notifications/read-all
Authorization: Bearer {{loginRecipient.response.body.data.accessToken}}

###

