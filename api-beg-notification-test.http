###############################################
# SECTION 14: NOTIFICATIONS
###############################################

### 14.1 Get All Notifications
GET {{baseUrl}}/api/notifications
Authorization: Bearer {{loginRecipient.response.body.data.accessToken}}

# ✅ Expected: 200 OK
# Should see:
# - "donation_received" notification
# - "beg_funded" notification (if beg reached 100%)

###

### 14.2 Get Unread Count
GET {{baseUrl}}/api/notifications/unread-count
Authorization: Bearer {{loginRecipient.response.body.data.accessToken}}

# ✅ Expected: { "data": { "unread_count": 2 } }

###

### 14.3 Mark Single Notification as Read
# @name getNotifications
GET {{baseUrl}}/api/notifications
Authorization: Bearer {{loginRecipient.response.body.data.accessToken}}

###

PATCH {{baseUrl}}/api/notifications/PASTE_NOTIFICATION_ID/read
Authorization: Bearer {{loginRecipient.response.body.data.accessToken}}

# ✅ Expected: 200 OK

###

### 14.4 Mark All Notifications as Read
PATCH {{baseUrl}}/api/notifications/read-all
Authorization: Bearer {{loginRecipient.response.body.data.accessToken}}

# ✅ Expected: 200 OK

