# -----------------------------------------------------------------------------
# Plz Backend Environment Example
# -----------------------------------------------------------------------------
# Copy this file to `.env` and replace placeholder values with real credentials.
# Never commit real secrets.

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:8081
EXPO_PUBLIC_FRONTEND_URL=http://localhost:8081
API_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000,http://localhost:5174
SUPPORT_EMAIL=support@plz.app
SCHEDULER_ENABLED=true
SCHEDULER_SECRET=replace-with-a-long-random-scheduler-secret
COOKIE_SECURE=false

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pliz?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/pliz?schema=public

# -----------------------------------------------------------------------------
# Redis / Cache
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

CACHE_USER_SESSION_TTL=604800
CACHE_EMAIL_TOKEN_TTL=86400
CACHE_OTP_TTL=600
CACHE_COUNTRIES_TTL=86400

# -----------------------------------------------------------------------------
# Auth / Sessions
# -----------------------------------------------------------------------------
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
COOKIE_SECURE=false

# Legacy names currently present in some local env files. Prefer the *_EXPIRY
# variables above because that is what src/config/security.ts reads.
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_TOKEN_EXPIRY_HOURS=24

# Withdrawal email service uses these SMTP_* variables.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_NAME=Plz
FROM_EMAIL=

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5

# -----------------------------------------------------------------------------
# Payments - Paystack
# -----------------------------------------------------------------------------
PAYSTACK_PUBLIC_KEY=pk_test_replace_me
PAYSTACK_SECRET_KEY=sk_test_replace_me
PAYSTACK_INCLUDE_TEST_BANKS=false

# -----------------------------------------------------------------------------
# KYC / Phone Verification
# -----------------------------------------------------------------------------
# Current KYC services use Prembly.
PREMBLY_API_KEY=
PREMBLY_APP_ID=
# Set to true to bypass Prembly identity checks locally (NIN + passport)
PREMBLY_SKIP_VERIFICATION=

# Phone verification via SendChamp OTP API (https://sendchamp.readme.io/reference/send-otp-api)
SENDCHAMP_API_KEY=
SENDCHAMP_SMS_SENDER=Plz
SENDCHAMP_WHATSAPP_SENDER=

TERMII_API_KEY=
YOUVERIFY_API_KEY=

# -----------------------------------------------------------------------------
# File Storage - Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=profile-pictures
SUPABASE_KYC_BUCKET=kyc-documents

# -----------------------------------------------------------------------------
# OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# -----------------------------------------------------------------------------
# AI / Emoji Integrations
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
EMOJI_API_KEY=

# -----------------------------------------------------------------------------
# AWS
# -----------------------------------------------------------------------------
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Admin console (plz-admin)
# -----------------------------------------------------------------------------
# Public URL of the admin SPA — used in team invite links
ADMIN_FRONTEND_URL=http://localhost:5174
# One-time bootstrap for the first super admin (run: npm run bootstrap-admin)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_USERNAME=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_TO_CONSOLE=true
LOG_TO_FILE=false
LOGS_DIR=logs

# -----------------------------------------------------------------------------
# Logging (Cloud Run: stdout JSON is always on; set LOG_TO_FILE=true only for local file logs)
LOG_LEVEL=info
LOG_TO_FILE=
# -----------------------------------------------------------------------------
OTP_EXPIRY_MINUTES=10
